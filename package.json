{
  "name": "@sharkord/desktop",
  "author": "TheBlindMagician",
  "description": "An Electron app for running Sharkord natively in windows",
  "version": "0.0.5",
  "main": "dist/index.js",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsc && electron --no-sandbox dist/index.js",
    "build": "rm -rf ./dist && tsc && electron-builder --win",
    "build:dir": "tsc && electron-builder --dir",
    "format": "prettier --write \"**/*.ts*\" --config ./.prettierrc.json",
    "lint": "eslint ./src/**/*.ts --ext ts --report-unused-disable-directives",
    "lint:fix": "eslint ./src/**/*.ts --ext ts --report-unused-disable-directives --fix",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist",
    "dist": "electron-builder",
    "release": "npm run clean && tsc && electron-builder --win --publish=always"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "electron": "^31.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^8.56.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "prettier": "^3.5.3",
    "prettier-plugin-organize-imports": "^4.1.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3"
  },
  "build": {
    "appId": "com.the-blind-magician.sharkord.desktop",
    "productName": "Sharkord",
    "files": [
      "dist/**/*",
      "node_modules/**",
      "package.json",
      "public/**"
    ],
    "win": {
      "icon": "public/icon.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "The-Blind-Magician",
        "repo": "sharkord-desktop"
      }
    ]
  }
}
